# VisiumGo Test Analyzer — environment configuration
# Copy to `.env` and adjust. `.env` is NOT committed; this file is.
# Defaults below run the whole chain with mocks (no VisiumGo, no real LLM).

# --- persistence / DB simulation (plan.md A12) ---
DATABASE_DIR=database
TABLE_RUNS=runs
TABLE_ANALYSIS_RESULTS=analysis_results
TABLE_EVIDENCE=evidence
TABLE_PROMPTS=prompts

# --- source / Halka 1 (registry key) ---
# mock | visiumgo   (visiumgo is a work-PC stub for now)
SOURCE_PROVIDER=mock
BANKS_CONFIG_PATH=config/banks.json

# --- extraction & size management / Halka 2 (plan.md A5, A11) ---
# mock | visiumgo   (visiumgo is a work-PC stub for now)
EXTRACTOR_PROVIDER=mock
# 0 = passthrough (no truncation). Set after the real model's context window
# is known on the work PC (plan.md A16). Trimming, when enabled, happens per
# Evidence (content selector) — there is no global trimmer.
TRUNCATION_THRESHOLD_TOKENS=0
TOKEN_CHARS_RATIO=4
# Per-evidence flags (plan.md A5.2) have sensible defaults in code
# (screenshots: goes_to_llm=false; everything stored). Override as JSON only if
# needed, e.g.:
# EVIDENCE_FLAGS={"BrowserLogEvidence":{"goes_to_llm":false,"goes_to_store":true}}

# --- precheck (registry key, plan.md A7) ---
# noop is the only implementation today (always defers to the LLM).
PRECHECK_PROVIDER=noop

# --- prompt / Halka 3 (plan.md A8) ---
PROMPT_TEMPLATE_PATH=config/prompt_template.txt
CONFIDENCE_BUCKETS=[0.1,0.25,0.5,0.75,0.99]

# --- LLM / Halka 4 (registry key) ---
# mock | openai_compatible
LLM_PROVIDER=mock
# Full OpenAI-compatible chat-completions URL of the on-prem LLM, e.g.
# LLM_API_URL=http://localhost:8080/v1/chat/completions
LLM_API_URL=
LLM_API_KEY=
LLM_MODEL=mock-model
LLM_TEMPERATURE=0
LLM_TIMEOUT_SECONDS=120
# LLM_MAX_TOKENS=

# --- API / background processing (plan.md A13) ---
MAX_CONCURRENCY=2
CACHE_ENABLED=true
