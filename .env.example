# VisiumGo Test Analyzer — environment configuration
# Copy to `.env` and adjust. `.env` is NOT committed; this file is.
# Defaults below run the whole chain with mocks (no VisiumGo, no real LLM).

# --- persistence / DB simulation (plan.md A10) ---
DATABASE_DIR=database
TABLE_RUNS=runs
TABLE_ANALYSIS_RESULTS=analysis_results
TABLE_EVIDENCE=evidence
TABLE_PROMPTS=prompts

# --- source / Halka 1 ---
# mock | visiumgo   (visiumgo is a work-PC stub for now)
SOURCE_PROVIDER=mock
BANKS_CONFIG_PATH=config/banks.json

# --- extraction / Halka 2 ---
# mock | visiumgo   (visiumgo is a work-PC stub for now)
EXTRACTOR_PROVIDER=mock
# 0 = passthrough (no truncation). Set after the real model's context window
# is known on the work PC (plan.md A13).
TRUNCATION_THRESHOLD_TOKENS=0
TOKEN_CHARS_RATIO=4

# --- prompt / Halka 3 ---
PROMPT_TEMPLATE_PATH=config/prompt_template.txt
CONFIDENCE_BUCKETS=[0.1,0.25,0.5,0.75,0.99]

# --- LLM / Halka 4 ---
# mock | openai_compatible
LLM_PROVIDER=mock
# Full OpenAI-compatible chat-completions URL of the on-prem LLM, e.g.
# LLM_API_URL=http://localhost:8080/v1/chat/completions
LLM_API_URL=
LLM_API_KEY=
LLM_MODEL=mock-model
LLM_TEMPERATURE=0
LLM_TIMEOUT_SECONDS=120
# LLM_MAX_TOKENS=

# --- API / background processing (plan.md A11) ---
MAX_CONCURRENCY=2
CACHE_ENABLED=true
